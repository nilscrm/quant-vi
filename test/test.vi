
use #root::debug;
use #quant::BinomialTree::{OptionType, price};

pub struct* TestData({
  label: String,
  spot: F64,
  strike: F64,
  option_type: OptionType,
  ttm: F64,
  iv: F64,
  r: F64,
  q: F64,
  n_steps: N32,
  price: F64,
});

pub mod TestData {
  pub fn new(
    label: String,
    spot: F64,
    strike: F64,
    option_type: OptionType,
    ttm: F64,
    iv: F64,
    r: F64,
    q: F64,
    n_steps: N32,
    price: F64,
  ) -> TestData {
    TestData({ label, spot, strike, option_type, ttm, iv, r, q, n_steps, price })
  }
}

const price_tolerance: F64 = 0.000000001[F64];

pub fn main(&io: &IO) {
  let passed = 0;
  let num_tests = test_data.len();
  for test_data in test_data {
    let actual = price(
      test_data.spot,
      test_data.strike,
      test_data.option_type,
      test_data.ttm,
      test_data.iv,
      test_data.r,
      test_data.q,
      test_data.n_steps,
    );
    let diff = (actual - test_data.price).abs();
    if diff <= price_tolerance {
      io.println("{test_data.label}: pass");
      passed += 1;
    } else {
      io.println("{test_data.label}: expected {test_data.price}, got {actual}, abs diff {diff}, tolerance {
        price_tolerance
      }");
    }
  }
  io.println("{passed} / {num_tests} cases passed");
  if passed != num_tests {
    debug::error("test failed");
  }
}

